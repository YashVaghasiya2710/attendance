<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="IMPORT HISTORY"
        android:textColor="@color/accent"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1. Copy this prompt and give to Gemini with your chat export:"
        android:textColor="@color/text"
        android:textSize="12sp"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/card"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="4dp"
        android:layout_marginBottom="16dp">
        <TextView
            android:id="@+id/tv_import_prompt"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:padding="8dp"
            android:textColor="@color/muted"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:text="Extract dates and times from the provided chat. Return ONLY a JSON array like: [{&quot;date&quot;: &quot;YYYY-MM-DD&quot;, &quot;in&quot;: &quot;hh:mm AM/PM&quot;, &quot;out&quot;: &quot;hh:mm AM/PM&quot;}]. Use empty string if OUT is missing." />
        <ImageButton
            android:id="@+id/btn_copy_prompt"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_input_add"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/accent"
            android:contentDescription="Copy Prompt" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2. Paste Gemini's response here:"
        android:textColor="@color/text"
        android:textSize="12sp"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/et_import_data"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:background="@drawable/bg_pill_subtle"
        android:gravity="top"
        android:hint="Paste JSON here..."
        android:padding="12dp"
        android:textColor="@color/text"
        android:textColorHint="@color/muted"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:inputType="textMultiLine"
        android:importantForAutofill="no" />

</LinearLayout>